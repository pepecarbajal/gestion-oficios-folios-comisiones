<%- include('partials/header') %>

  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-top">
        <nav class="nav">
          <a href="#" class="nav-item active" id="navOficios" onclick="cambiarTab('oficios', event)">
            Oficios
          </a>
          <a href="#" class="nav-item" id="navAtendidos" onclick="cambiarTab('atendidos', event)">
            Atendidos
          </a>
        </nav>
      </div>
      <div class="sidebar-bottom">
        <span class="rol-label">Asistente de Folios</span>
        <form action="/logout" method="POST" style="margin:0" id="formLogout">
          <input type="hidden" name="_csrf" id="csrfLogout">
          <button type="submit" class="logout">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
               <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
               <polyline points="16 17 21 12 16 7"/>
               <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Salir
          </button>
        </form>
      </div>
    </aside>
    <main class="main">
      <div id="tabOficios" class="content-card tab-panel">
        <div class="card-header">
          <div class="filters">
            <div class="search-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" id="searchOficios" placeholder="Buscar..." class="search-input">
            </div>
            <select id="filterEstatusOf" class="filter-select">
              <option value="">Todos</option>
              <option value="Pendiente">Pendiente</option>
              <option value="Vencido">Vencido</option>
            </select>
            <select id="filterUnidadOf" class="filter-select">
              <option value="">Todas las unidades</option>
              <option value="TODAS">TODAS</option>
              <% unidades.forEach(u => { %>
                <option value="<%= u.alias %>"><%= u.alias %></option>
              <% }) %>
            </select>
          </div>
          <button class="btn-primary" id="btnNuevoOficio">+ Registrar</button>
        </div>

        <table class="table" id="tablaOficios">
          <thead>
            <tr>
              <th>No. Oficio</th>
              <th>Remitente</th>
              <th>Asunto</th>
              <th>Fecha</th>
              <th>Unidad</th>
              <th>Prioridad</th>
              <th>Acción</th>
            </tr>
          </thead>
          <tbody id="tbodyOficios">
            <% if (oficiosPend.length === 0) { %>
              <tr><td colspan="8" class="empty-state">No hay oficios pendientes.</td></tr>
            <% } %>
            <% oficiosPend.forEach(o => {
               const limite = o.fechaLimite ? new Date(o.fechaLimite) : null;
               if (limite) limite.setHours(23,59,59,999);
               const vencido = limite && limite < new Date();
               const urgente = !vencido && limite && (limite - new Date()) / (1000 * 60 * 60 * 24) <= 6;
               const prioridad = vencido ? 'vencido' : urgente ? 'urgente' : 'en-tiempo';
               const estatus = vencido ? 'Vencido' : o.estatus;
               const initials = o.remitente ? o.remitente.slice(0,2).toUpperCase() : '??';
               const respuestas = o.respuestas || [];
            %>
              <tr class="oficio-row of-row"
                data-estatus="<%= estatus %>"
                data-unidad="<%= o.unidadAlias || '' %>"
                data-search="<%= (o.noOficio + ' ' + o.remitente + ' ' + o.asunto).toLowerCase() %>"
                data-id="<%= o.id %>">
                <td class="no-cell"><%= o.noOficio %></td>
                <td>
                  <%- include('partials/user-cell', { name: o.remitente, initials: initials, cargo: o.cargo }) %>
                </td>
                <td class="asunto-cell" title="<%= o.asunto %>"><%= o.asunto %></td>
                <td class="fecha-cell">
                  <%= o.fechaOficio ? new Date(o.fechaOficio).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric'}) : '—' %>
                  <% if (o.fechaLimite) { %>
                    <span class="fecha-limite <%= vencido ? 'vencida' : '' %>">
                      Límite: <%= new Date(o.fechaLimite).toLocaleDateString('es-MX', {day:'2-digit',month:'short'}) %>
                    </span>
                  <% } %>
                </td>
                <td><%= o.unidadAlias || '—' %></td>
                <td>
                  <span class="badge badge-prioridad badge-<%= prioridad %>"><%= prioridad === 'vencido' ? 'Vencido' : prioridad === 'urgente' ? 'Urgente' : 'En tiempo' %></span>
                </td>
                <td class="actions-cell">
                  <% if (o.archivoUrl) { %>
                    <a href="<%= o.archivoUrl %>" target="_blank" class="icon-btn" title="Ver PDF original">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                  <% } %>
                  <% if (respuestas.length > 0) { %>
                    <button class="icon-btn" title="Ver respuestas" data-oficio-id="<%= o.id %>" onclick="abrirModalRespuestas(this)">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </button>
                  <% } %>
                  <button class="icon-btn btn-cambiar-estatus" title="Cambiar estatus" data-id="<%= o.id %>" data-estatus="<%= o.estatus %>">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </button>
                </td>
              </tr>
              <tr class="respuestas-row" id="resp-<%= o.id %>" style="display:none">
                <td colspan="7">
                  <div class="respuestas-panel">
                    <% respuestas.forEach(r => { %>
                      <div class="respuesta-item">
                        <div class="respuesta-body">
                          <div class="respuesta-header">
                            <span class="resp-alias"><%= r.unidadAlias %></span>
                            <span class="resp-fecha">Atendido: <%= new Date(r.fechaAtendido).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric', hour:'2-digit', minute:'2-digit'}) %></span>
                          </div>
                          <% if (r.comentario || (r.archivos && r.archivos.length > 0)) { %>
                            <div class="respuesta-divider"></div>
                          <% } %>
                          <% if (r.comentario) { %>
                            <p class="resp-comentario">"<%= r.comentario %>"</p>
                          <% } %>
                          <% if (r.archivos && r.archivos.length > 0) { %>
                            <div class="resp-archivos">
                               <% r.archivos.forEach(a => { %>
                                 <%- include('partials/file-chip', { url: a.url, tipo: a.tipo, nombre: a.nombre }) %>
                               <% }) %>
                            </div>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div class="pagination">
          <span id="paginacionInfoOf">Mostrando <%= oficiosPend.length %> de <%= oficiosPend.length %></span>
        </div>
      </div>
      <div id="tabAtendidos" class="content-card tab-panel" style="display:none">
        <div class="card-header">
          <div class="filters">
            <div class="search-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input type="text" id="searchAtendidos" placeholder="Buscar..." class="search-input">
            </div>
            <select id="filterUnidadAt" class="filter-select">
              <option value="">Todas las unidades</option>
              <option value="TODAS">TODAS</option>
              <% unidades.forEach(u => { %>
                <option value="<%= u.alias %>"><%= u.alias %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <% if (oficiosAt.length === 0) { %>
          <div class="empty-state-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            <p>No hay oficios atendidos aún.</p>
          </div>
        <% } else { %>
          <table class="table" id="tablaAtendidos">
            <thead>
              <tr>
                <th>No.</th>
                <th>Remitente</th>
                <th>Asunto</th>
                <th>Fecha</th>
                <th>Unidad</th>
                <th>Respuestas</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody id="tbodyAtendidos">
              <% oficiosAt.forEach(o => {
                 const respuestas = o.respuestas || [];
                 const totalResp = respuestas.length;
                 const initials = o.remitente ? o.remitente.slice(0,2).toUpperCase() : '??';
              %>
                <tr class="oficio-row at-row"
                  data-unidad="<%= o.unidadAlias || '' %>"
                  data-search="<%= (o.noOficio + ' ' + o.remitente + ' ' + o.asunto + ' ' + (o.unidadAlias || '')).toLowerCase() %>"
                  data-id="<%= o.id %>">
                  <td class="no-cell"><%= o.noOficio %></td>
                  <td>
                    <%- include('partials/user-cell', { name: o.remitente, initials: initials, cargo: o.cargo }) %>
                  </td>
                  <td class="asunto-cell" title="<%= o.asunto %>"><%= o.asunto %></td>
                  <td class="fecha-cell">
                    <%= o.fechaOficio ? new Date(o.fechaOficio).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric'}) : '—' %>
                  </td>
                  <td><%= o.unidadAlias || '—' %></td>
                  <td>
                    <span class="resp-label"><%= totalResp %> respuesta<%= totalResp !== 1 ? 's' : '' %></span>
                    <script type="application/json" id="resp-data-<%= o.id %>"><%- JSON.stringify(respuestas).replace(/<\/script>/gi,'<\/script>') %></script>
                    <script>
                      window.__respuestas = window.__respuestas || {};
                      window.__respuestas['<%= o.id %>'] = JSON.parse(document.getElementById('resp-data-<%= o.id %>').textContent);
                    </script>
                  </td>
                  <td class="actions-cell">
                    <% if (o.archivoUrl) { %>
                      <a href="<%= o.archivoUrl %>" target="_blank" class="icon-btn" title="Ver oficio original">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                      </a>
                    <% } %>
                    <button class="icon-btn" title="Ver respuestas" data-oficio-id="<%= o.id %>" onclick="abrirModalRespuestas(this)">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div class="pagination">
            <span id="paginacionInfoAt">Mostrando <%= oficiosAt.length %> de <%= oficiosAt.length %></span>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <%# MODAL REGISTRAR OFICIO %>
  <div class="modal-overlay" id="modalOficioOverlay">
    <div class="modal">
      <div class="modal-header">
        <h3>Registrar Oficio</h3>
        <button class="modal-close" id="modalOficioClose">&times;</button>
      </div>
      <div class="modal-body">
        <p class="modal-error" id="modalOficioError"></p>
        <div class="form-row">
          <div class="form-group">
            <label>No. Oficio</label>
            <input type="text" id="inputNoOficio" placeholder="OF-2024-005">
          </div>
          <div class="form-group">
            <label>Fecha del Oficio</label>
            <input type="date" id="inputFechaOficio">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Fecha de Recibo</label>
            <input type="date" id="inputFechaRecibo">
          </div>
          <div class="form-group">
            <label>Fecha Límite</label>
            <input type="date" id="inputFechaLimite">
          </div>
        </div>
        <div class="form-group">
          <label>Asunto</label>
          <textarea id="inputAsunto" placeholder="Describa brevemente el asunto" rows="3"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Remitente</label>
            <input type="text" id="inputRemitente" placeholder="Nombre completo">
          </div>
          <div class="form-group">
            <label>Cargo</label>
            <input type="text" id="inputCargo" placeholder="Cargo del remitente">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Dependencia</label>
            <input type="text" id="inputDependencia" placeholder="Dependencia de origen">
          </div>
          <div class="form-group">
            <label>Unidad a Turnar</label>
            <select id="inputUnidadTurnar">
              <option value="" disabled selected>Seleccionar</option>
              <option value="TODAS" data-alias="TODAS">— Todas las unidades —</option>
              <% unidades.forEach(u => { %>
                <option value="<%= u.id %>" data-alias="<%= u.alias %>"><%= u.uadname %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Adjuntar Oficio <span class="label-hint">(PDF, opcional)</span></label>
          <div class="file-drop" id="fileDrop">
            <input type="file" id="inputArchivo" accept="application/pdf" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
            <span id="fileLabel">Seleccionar archivo PDF</span>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="btnOficioCancelar">Cancelar</button>
        <button class="btn-primary" id="btnOficioRegistrar">
          <span id="btnRegistrarText">Registrar</span>
          <span id="btnRegistrarLoader" class="loader" style="display:none"></span>
        </button>
      </div>
    </div>
  </div>

  <%# MODAL CAMBIAR ESTATUS %>
  <div class="modal-overlay" id="modalEstatusOverlay">
    <div class="modal modal-sm">
      <div class="modal-header">
        <h3>Cambiar Estatus</h3>
        <button class="modal-close" id="modalEstatusClose">&times;</button>
      </div>
      <div class="modal-body">
        <p class="modal-error" id="modalEstatusError"></p>
        <div class="form-group">
          <label>Nuevo Estatus</label>
          <select id="selectNuevoEstatus">
            <option value="Pendiente">Pendiente</option>
            <option value="Atendido">Atendido</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="btnEstatusCancelar">Cancelar</button>
        <button class="btn-primary" id="btnEstatusGuardar">Guardar</button>
      </div>
    </div>
  </div>

  <%# MODAL RESPUESTAS %>
  <div class="modal-overlay" id="modalRespuestasOverlay">
    <div class="modal modal-respuestas">
      <div class="modal-header">
        <h3 id="modalRespuestasTitulo">Respuestas</h3>
        <button class="modal-close" id="modalRespuestasClose">&times;</button>
      </div>
      <div class="modal-body">
        <div id="listaRespuestasModal"></div>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="btnRespuestasCerrar">Cerrar</button>
      </div>
    </div>
  </div>

  <script src="/js/dashboardaof.js"></script>

<%- include('partials/footer') %>