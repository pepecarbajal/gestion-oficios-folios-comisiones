<%- include('partials/header') %>

  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-top">
        <nav class="nav">
          <a href="#" class="nav-item active" id="navPendientes" onclick="cambiarTab('pendientes', event)">
            Oficios
          </a>
          <a href="#" class="nav-item" id="navAtendidos" onclick="cambiarTab('atendidos', event)">
            Atendidos
          </a>
        </nav>
      </div>
      <div class="sidebar-bottom">
        <span class="rol-label"><%= unidadAlias || 'Unidad Administrativa' %></span>
        <form action="/logout" method="POST" style="margin:0" id="formLogout">
          <input type="hidden" name="_csrf" id="csrfLogout">
          <button type="submit" class="logout">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
               <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
               <polyline points="16 17 21 12 16 7"/>
               <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Salir
          </button>
        </form>
      </div>
    </aside>
    <main class="main">
      <div id="tabPendientes" class="content-card tab-panel">
        <div class="card-header">
          <div class="filters">
            <div class="search-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" id="searchPendientes" placeholder="Buscar..." class="search-input">
            </div>
            <select id="filterEstatusPend" class="filter-select">
              <option value="">Todos</option>
              <option value="Pendiente">Pendiente</option>
              <option value="Vencido">Vencido</option>
            </select>
          </div>
        </div>

        <table class="table">
          <thead>
            <tr>
              <th>No.</th>
              <th>Remitente</th>
              <th>Asunto</th>
              <th>Fecha</th>
              <th>Límite</th>
              <th>Prioridad</th>
              <th>Acción</th>
            </tr>
          </thead>
          <tbody id="tbodyPendientes">
            <% if (oficiosPend.length === 0) { %>
              <tr><td colspan="7" class="empty-state">No tienes oficios pendientes.</td></tr>
            <% } %>
            <% oficiosPend.forEach(o => {
               const limite = o.fechaLimite ? new Date(o.fechaLimite) : null;
               if (limite) limite.setHours(23,59,59,999);
               const vencido = limite && limite < new Date();
               const urgente = !vencido && limite && (limite - new Date()) / (1000 * 60 * 60 * 24) <= 6;
               const prioridad = vencido ? 'vencido' : urgente ? 'urgente' : 'en-tiempo';
               const estatusGlobal = vencido ? 'Vencido' : o.estatus;
               const initials = o.remitente ? o.remitente.slice(0,2).toUpperCase() : '??';
               const respuestas = o.respuestas || [];
               const miRespuesta = respuestas.find(r => r.unidadId === unidadId);
               const yaRespondio = !!miRespuesta;
            %>
              <tr class="oficio-row pend-row"
                data-estatus="<%= estatusGlobal %>"
                data-search="<%= (o.noOficio + ' ' + o.remitente + ' ' + o.asunto).toLowerCase() %>">
                <td class="no-cell"><%= o.noOficio %></td>
                <td>
                  <%- include('partials/user-cell', { name: o.remitente, initials: initials, cargo: o.cargo }) %>
                </td>
                <td class="asunto-cell" title="<%= o.asunto %>"><%= o.asunto %></td>
                <td>
                  <%= o.fechaOficio
                    ? new Date(o.fechaOficio).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric'})
                    : '—' %>
                </td>
                <td>
                  <% if (o.fechaLimite) { %>
                    <span class="fecha-limite-cell <%= vencido ? 'vencida' : '' %>">
                      <%= new Date(o.fechaLimite).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric'}) %>
                    </span>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge badge-prioridad badge-<%= prioridad %>"><%= prioridad === 'vencido' ? 'Vencido' : prioridad === 'urgente' ? 'Urgente' : 'En tiempo' %></span>
                </td>
                <td class="actions-cell">
                  <% if (o.archivoUrl) { %>
                    <a href="javascript:void(0)" onclick="openFileViewer('<%= o.archivoUrl %>', 'Oficio <%= o.noOficio %>')" class="icon-btn" title="Ver oficio PDF">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                  <% } %>
                  <button class="icon-btn btn-responder"
                    title="<%= yaRespondio ? 'Editar respuesta' : 'Responder' %>"
                    data-id="<%= o.id %>"
                    data-comentario="<%= yaRespondio ? (miRespuesta.comentario || '').replace(/"/g, '&quot;') : '' %>"
                    data-archivos="<%= yaRespondio ? JSON.stringify(miRespuesta.archivos || []).replace(/"/g, '&quot;') : '[]' %>"
                    data-ya="<%= yaRespondio %>">
                    <% if (yaRespondio) { %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    <% } else { %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <% } %>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div class="pagination">
          <span id="paginacionInfoPend">Mostrando <%= oficiosPend.length %> de <%= oficiosPend.length %></span>
        </div>
      </div>
      <div id="tabAtendidos" class="content-card tab-panel" style="display:none">
        <div class="card-header">
          <div class="filters">
            <div class="search-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input type="text" id="searchAtendidos" placeholder="Buscar..." class="search-input">
            </div>
          </div>
        </div>

        <% if (oficiosAtend.length === 0) { %>
          <div class="empty-state-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            <p>Aún no has respondido ningún oficio.</p>
          </div>
        <% } else { %>
          <table class="table">
            <thead>
              <tr>
                <th>No.</th>
                <th>Remitente</th>
                <th>Asunto</th>
                <th>Fecha oficio</th>
                <th>Respondido</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody id="tbodyAtendidos">
              <% oficiosAtend.forEach(o => {
                 const miRespuesta = (o.respuestas || []).find(r => r.unidadId === unidadId);
                 const initials = o.remitente ? o.remitente.slice(0,2).toUpperCase() : '??';
                 const archivos = miRespuesta.archivos || [];
              %>
                <tr class="atendido-row atend-row"
                  data-search="<%= (o.noOficio + ' ' + o.remitente + ' ' + o.asunto).toLowerCase() %>"
                  data-id="<%= o.id %>">
                  <td class="no-cell"><%= o.noOficio %></td>
                  <td>
                    <%- include('partials/user-cell', { name: o.remitente, initials: initials, cargo: o.cargo }) %>
                  </td>
                  <td class="asunto-cell" title="<%= o.asunto %>"><%= o.asunto %></td>
                  <td class="fecha-cell">
                    <%= o.fechaOficio
                      ? new Date(o.fechaOficio).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric'})
                      : '—' %>
                  </td>
                  <td class="fecha-cell">
                    <span class="fecha-respuesta">
                      <%= new Date(miRespuesta.fechaAtendido).toLocaleDateString('es-MX', {day:'2-digit',month:'short',year:'numeric'}) %>
                    </span>
                    <% if (miRespuesta.comentario) { %>
                      <span class="fecha-limite" title="<%= miRespuesta.comentario %>">"<%= miRespuesta.comentario.length > 30 ? miRespuesta.comentario.slice(0,30) + '…' : miRespuesta.comentario %>"</span>
                    <% } %>
                  </td>
                  <td class="actions-cell">
                    <% if (o.archivoUrl) { %>
                      <a href="javascript:void(0)" onclick="openFileViewer('<%= o.archivoUrl %>', 'Oficio <%= o.noOficio %>')" class="icon-btn" title="Ver oficio PDF">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                      </a>
                    <% } %>
                    <% if (archivos.length > 0) { %>
                      <button class="icon-btn btn-ver-evidencias" title="Ver evidencias (<%= archivos.length %> archivo<%= archivos.length > 1 ? 's' : '' %>)"
                        data-oficio-id="<%= o.id %>"
                        onclick="abrirEvidencias(this)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                      </button>
                      <script type="application/json" id="evid-data-<%= o.id %>"><%- JSON.stringify(archivos).replace(/<\/script>/gi,'<\/script>') %></script>
                      <script>
                        window.__evidencias = window.__evidencias || {};
                        window.__evidencias['<%= o.id %>'] = JSON.parse(document.getElementById('evid-data-<%= o.id %>').textContent);
                      </script>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div class="pagination">
            <span id="paginacionInfoAtend">Mostrando <%= oficiosAtend.length %> de <%= oficiosAtend.length %></span>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <%# MODAL VISOR DE ARCHIVOS %>
  <%- include('partials/viewer-modal') %>

  <%# MODAL RESPUESTA %>
  <div class="modal-overlay" id="modalRespuestaOverlay">
    <div class="modal">
      <div class="modal-header">
        <h3 id="modalRespuestaTitulo">Responder Oficio</h3>
        <button class="modal-close" id="modalRespuestaClose">&times;</button>
      </div>
      <div class="modal-body">
        <p class="modal-error" id="modalRespuestaError"></p>
        <div class="form-group">
          <label>Comentario <span class="label-hint">(opcional)</span></label>
          <textarea id="inputComentario" placeholder="Describa brevemente cómo fue atendido el oficio..." rows="4"></textarea>
        </div>
        <div class="form-group">
          <label>Evidencias <span class="label-hint">(PDF e imágenes, múltiples archivos)</span></label>
          <div class="file-drop-multi" id="fileDropMulti">
            <input type="file" id="inputEvidencias" accept="application/pdf,image/*" multiple hidden>
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
            <span id="fileLabelMulti">Arrastra archivos aquí o haz clic para seleccionar</span>
          </div>
          <div id="listaArchivos" class="lista-archivos"></div>
        </div>
        <div id="archivosExistentes" class="archivos-existentes" style="display:none">
          <p class="archivos-existentes-label">Archivos ya subidos:</p>
          <div id="listaArchivosExistentes"></div>
          <p class="archivos-existentes-hint">Los nuevos archivos que subas se agregarán a los existentes.</p>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="btnRespuestaCancelar">Cancelar</button>
        <button class="btn-primary" id="btnRespuestaGuardar">
          <span id="btnGuardarText">Guardar</span>
          <span id="btnGuardarLoader" class="loader" style="display:none"></span>
        </button>
      </div>
    </div>
  </div>

  <%# MODAL EVIDENCIAS %>
  <div class="modal-overlay" id="modalEvidenciasOverlay">
    <div class="modal">
      <div class="modal-header">
        <h3>Evidencias</h3>
        <button class="modal-close" id="modalEvidenciasClose">&times;</button>
      </div>
      <div class="modal-body">
        <div id="listaEvidenciasModal" style="display:flex;flex-direction:column;gap:8px;"></div>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="btnEvidenciasCerrar">Cerrar</button>
      </div>
    </div>
  </div>

  <script src="/js/viewer.js"></script>
  <script src="/js/dashboarduad.js"></script>

<%- include('partials/footer') %>